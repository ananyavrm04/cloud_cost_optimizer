# Optional config file (Enhancement #55)
# Environment variables always override these values.

SUBMISSION_MODE: true
MODEL_NAME: openai/gpt-oss-20b:fastest
MAX_STEPS: 100
LLM_TIMEOUT_SECONDS: 20
LLM_MAX_RETRIES: 2
HISTORY_WINDOW: 5
LLM_FAILURE_THRESHOLD: 3
NEGATIVE_STREAK_THRESHOLD: 3
ENV_HEALTH_RETRIES: 5
ENV_HEALTH_BACKOFF_SECONDS: 1.0
