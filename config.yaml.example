# Optional config file (Enhancement #55)
# Environment variables always override these values.

SUBMISSION_MODE: true
MODEL_NAME: openai/gpt-oss-20b:fastest
PROMPT_VERSION: v1
MAX_STEPS: 100
LLM_TIMEOUT_SECONDS: 20
LLM_MAX_RETRIES: 2
HISTORY_WINDOW: 5
LLM_FAILURE_THRESHOLD: 3
NEGATIVE_STREAK_THRESHOLD: 3
ENV_HEALTH_RETRIES: 5
ENV_HEALTH_BACKOFF_SECONDS: 1.0
NOOP_STREAK_THRESHOLD: 3
FALLBACK_MODEL_NAME: ""
MODEL_FALLBACKS: ""
PROMPT_CACHE_ENABLED: true
EMIT_TOKEN_LOGS: false
LLM_CONTEXT_WINDOW: 8
ENV_CALL_RETRIES: 2
EMIT_PROJECTED_LOGS: false
PROMPT_COST_PER_1K_TOKENS: 0.0
COMPLETION_COST_PER_1K_TOKENS: 0.0
