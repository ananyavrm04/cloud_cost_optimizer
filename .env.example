API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=openai/gpt-oss-120b:fastest
PROMPT_VERSION=v1
FALLBACK_MODEL_NAME=openai/gpt-oss-20b:fastest
# Optional comma-separated model chain after MODEL_NAME/FALLBACK_MODEL_NAME
MODEL_FALLBACKS=openai/gpt-oss-20b:cheapest
API_KEY=your_api_key_here
ENV_URL=http://localhost:7860
NOOP_STREAK_THRESHOLD=3
LLM_MAX_RETRIES=2
FORCE_LLM_EVERY_STEP=1
STEP_TIMEOUT_SECONDS=30
USE_CLIENT_RECONNECT_WRAPPER=1
INTERACTIVE_MODE=0
ENSEMBLE_VOTES=1
ENSEMBLE_TEMPERATURE=0.1
WARM_START_STEPS=0
EMIT_PROJECTED_LOGS=0
PROMPT_MAX_CHARS=12000
PROMPT_COST_PER_1K_TOKENS=0
COMPLETION_COST_PER_1K_TOKENS=0
# New optional enhancements (all disabled by default)
ENV_SEED=
SLA_PENALTY_CAP=0.3
ENABLE_RESOURCE_TAGS=0
TOKEN_BUDGET_PER_TASK=0
MIN_MARGINAL_GAIN=0.0
SELF_REFLECT_EVERY_N=0
ENABLE_TEMP_ANNEALING=0
NORMALIZE_REWARDS=0
ENABLE_UNDO_RESIZE=0
TWO_PHASE_RISK_THRESHOLD=0
PROGRESSIVE_MODE=0
CURRICULUM_CARRY_PATTERNS=0
